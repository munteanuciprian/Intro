import re

def eval_polinom(polinom_str, valoare_x):
    expresie = polinom_str.replace(" ", "")
    expresie = polinom_str.replace("^", "**")

    expresie = re.sub(r'(\d+)x', r'\1*x', expresie)
    x = valoare_x

    rezultat = eval(expresie)
    return rezultat

polinom = "3x ^ 3 + 5x ^ 2 - 2x - 5"
print(f"Valoarea polinomului pentru x=2 este: {eval_polinom(polinom, 2)}")
