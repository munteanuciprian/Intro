def operation(x, y, op):
    if op == "+":
        return x + y
    elif op == "-":
        return x - y
    elif op == "/":
        if y != 0:
            return x / y
        else:
            return "Error: divide by 0!"
    elif op == "*":
        return x * y
    else:
        return "Error: no valid operation"

print("3 + 5 =", operation(3, 5, "+"))
print("8 - 10 =", operation(8, 10, "-"))
print("27 / 12 =", operation(27, 12, "/"))
print("26 * 17 =", operation(26, 17, "*"))